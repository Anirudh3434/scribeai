{
  "manifest_version": 3,
  "name": "ScribeAI - AI Writing Assistant",
  "version": "1.0.0",
  "description": "Improve your writing in any text field or editor on any website using ChatGPT or Gemini APIs.",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
